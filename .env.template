# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- Twilio (I.twilio, Invariant 8) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Supabase (I.data) ---
SUPABASE_URL=
