ELEVENLABS_AGENT_ID=

# --- ngrok tunnel ---
NGROK_AUTHTOKEN=
# Set after `ngrok http` starts, or pin a reserved domain here if you have one.
PUBLIC_BASE_URL=

# --- Webhook server ---
PORT=8000
